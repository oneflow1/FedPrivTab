[Unit]
Description=FedPrivTab Streamlit UI
After=network.target fedprivtab-api.service
Wants=fedprivtab-api.service

[Service]
Type=simple
User=fedprivtab
Group=fedprivtab
WorkingDirectory=/opt/fedprivtab
Environment=PYTHONUNBUFFERED=1
Environment=STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
ExecStart=/opt/fedprivtab/.venv/bin/streamlit run streamlit_app.py --server.address 0.0.0.0 --server.port 8501 --server.headless true --browser.gatherUsageStats false
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
